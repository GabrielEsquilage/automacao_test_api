{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "RegraListItemDTO",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int32"
    },
    "nome": {
      "type": "string"
    },
    "tipoRegra": {
      "$ref": "TipoRepasseDTO.json"
    },
    "origem": {
      "type": "string",
      "enum": [
        "GERAL",
        "PERSONALIZADA"
      ]
    },
    "grupos": {
      "type": "string"
    },
    "dataInicial": {
      "type": "string",
      "format": "date"
    },
    "ativo": {
      "type": "boolean"
    }
  }
}