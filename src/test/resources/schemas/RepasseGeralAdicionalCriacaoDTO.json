{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "RepasseGeralAdicionalCriacaoDTO",
  "required": [
    "acrescimoPorId",
    "gruposIds",
    "nome",
    "porcentagemAdicional",
    "receberPorId",
    "serieInicialId",
    "tipoFilialIds"
  ],
  "type": "object",
  "properties": {
    "nome": {
      "maxLength": 255,
      "minLength": 0,
      "type": "string"
    },
    "tipoFilialIds": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "int32"
      }
    },
    "acrescimoPorId": {
      "type": "integer",
      "format": "int32"
    },
    "receberPorId": {
      "type": "integer",
      "format": "int32"
    },
    "gruposIds": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "int32"
      }
    },
    "serieInicialId": {
      "type": "integer",
      "format": "int32"
    },
    "serieFinalId": {
      "type": "integer",
      "format": "int32"
    },
    "porcentagemAdicional": {
      "maximum": 100.0,
      "exclusiveMaximum": false,
      "minimum": 1.0,
      "exclusiveMinimum": false,
      "type": "number"
    }
  }
}