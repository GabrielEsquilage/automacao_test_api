      "type": "integer",
      "format": "int32"
    },
    "nome": {
      "type": "string"
    },
    "tipoRegra": {
      "$ref": "TipoRepasseDTO.json"
    },
    "acrescimoPor": {
      "$ref": "TipoRepasseDTO.json"
    },
    "receberPor": {
      "$ref": "TipoRepasseDTO.json"
    },
    "serieInicial": {
      "$ref": "TipoRepasseDTO.json"
    },
    "serieFinal": {
      "$ref": "TipoRepasseDTO.json"
    },
    "porcentagemAdicional": {
      "type": "number"
    },
    "ativo": {
      "type": "boolean"
    },
    "criacao": {
      "type": "string",
      "format": "date-time"
    },
    "alteracao": {
      "type": "string",
      "format": "date-time"
    },
    "grupos": {
