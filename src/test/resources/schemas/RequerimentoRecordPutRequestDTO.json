{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "RequerimentoRecordPutRequestDTO",
  "required": [
    "liberacaoStatusMatriculaIds",
    "nivelEnsino",
    "possuiDisponibilidadeEspecifica"
