{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "UsuarioRecordResponseDTO",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int32"
    },
    "criacao": {
      "type": "string",
      "format": "date-time"
    },
    "alteracao": {
      "type": "string",
      "format": "date-time"
    },
    "ativo": {
      "type": "boolean"
    },
    "login": {
      "type": "string"
    },
    "pessoa": {
      "$ref": "PessoaRecordResponseDTO.json"
    },
    "departamento": {
      "$ref": "DepartamentoRecordCleanDTO.json"
    },
    "usuarioPerfis": {
      "type": "array",
      "items": {
        "$ref": "UsuarioPerfilRecordResponseDTO.json"
      }
    },
    "usuarioFuncionalidades": {
      "type": "array",
      "items": {
        "$ref": "UsuarioFuncionalidadeRecordResponseDTO.json"
      }
    },
    "totalSetores": {
      "type": ["integer", "null"],
      "format": "int64"
    }
  }
}