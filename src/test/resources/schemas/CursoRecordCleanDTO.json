{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "CursoRecordCleanDTO",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int32"
    },
    "criacao": {
      "type": ["string", "null"]
    },
    "alteracao": {
      "type": ["string", "null"]
    },
    "ativo": {
      "type": ["boolean", "null"]
    },
    "nome": {
      "type": "string"
    },
    "codigo": {
      "type": ["string", "null"]
    },
    "areaConhecimento": {
      "anyOf": [
        { "$ref": "AreaConhecimentoRecordCleanDTO.json" },
        { "type": "null" }
      ]
    },
    "inep": {
      "type": ["string", "null"]
    },
    "nivelEnsino": {
      "anyOf": [
        { "$ref": "NivelEnsinoRecordCleanDTO.json" },
        { "type": "null" }
      ]
    },
    "tipoCurso": {
      "anyOf": [
        { "$ref": "TipoCursoRecordCleanDTO.json" },
        { "type": "null" }
      ]
    },
    "grupoCurso": {
      "anyOf": [
        { "$ref": "GrupoCursoRecordCleanDTO.json" },
        { "type": "null" }
      ]
    },
    "modalidade": {
      "anyOf": [
        { "$ref": "ModalidadeRecordCleanDTO.json" },
        { "type": "null" }
      ]
    },
    "inicioFuncionamento": {
      "type": ["string", "null"],
      "format": "date"
    },
    "habilitacaoMasculino": {
      "type": ["string", "null"]
    },
    "habilitacaoFeminino": {
      "type": ["string", "null"]
    },
    "grauConferido": {
      "type": ["string", "null"]
    },
    "vagasAnuais": {
      "type": ["integer", "null"],
      "format": "int32"
    },
    "coordenador": {
      "anyOf": [
        { "$ref": "ColaboradorRecordCleanDTO.json" },
        { "type": "null" }
      ]
    },
    "descricaoConhecimento": {
      "type": ["string", "null"]
    },
    "autorizacao": {
      "type": ["string", "null"]
    },
    "credenciamento": {
      "type": ["string", "null"]
    },
    "reconhecimentos": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "$ref": "CursoReconhecimentoRecordCleanForCursoDTO.json"
          }
        },
        { "type": "null" }
      ]
    },
    "resolucao": {
      "type": ["string", "null"]
    },
    "segundaGraduacao": {
      "type": ["boolean", "null"]
    }
  }
}