{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "CursoRecordCleanDTO",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int32"
    },
    "criacao": {
      "type": "string",
      "format": "date-time"
    },
    "alteracao": {
      "type": "string",
      "format": "date-time"
    },
    "ativo": {
      "type": "boolean"
    },
    "nome": {
      "type": "string"
    },
    "codigo": {
      "type": "string"
    },
    "areaConhecimento": {
      "$ref": "AreaConhecimentoRecordCleanDTO.json"
    },
    "inep": {
      "type": "string"
    },
    "nivelEnsino": {
      "$ref": "NivelEnsinoRecordCleanDTO.json"
    },
    "tipoCurso": {
      "$ref": "TipoCursoRecordCleanDTO.json"
    },
    "grupoCurso": {
      "$ref": "GrupoCursoRecordCleanDTO.json"
    },
    "modalidade": {
      "$ref": "ModalidadeRecordCleanDTO.json"
    },
    "inicioFuncionamento": {
      "type": "string",
      "format": "date"
    },
    "habilitacaoMasculino": {
      "type": "string"
    },
    "habilitacaoFeminino": {
      "type": "string"
    },
    "grauConferido": {
      "type": "string"
    },
    "vagasAnuais": {
      "type": "integer",
      "format": "int32"
    },
    "coordenador": {
      "$ref": "ColaboradorRecordCleanDTO.json"
    },
    "descricaoConhecimento": {
      "type": "string"
    },
    "autorizacao": {
      "type": "string"
    },
    "credenciamento": {
      "type": "string"
    },
    "reconhecimentos": {
      "type": "array",
      "items": {
        "$ref": "CursoReconhecimentoRecordCleanForCursoDTO.json"
      }
    },
    "resolucao": {
      "type": "string"
    },
    "segundaGraduacao": {
      "type": "boolean"
    }
