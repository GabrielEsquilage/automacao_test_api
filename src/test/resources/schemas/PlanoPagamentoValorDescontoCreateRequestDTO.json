{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "PlanoPagamentoValorDescontoCreateRequestDTO",
  "required": [
    "nome",
    "parcelaInicial",
    "tipoParametroId",
    "valor"
  ],
  "type": "object",
  "properties": {
    "nome": {
      "maxLength": 50,
      "minLength": 0,
      "type": "string"
    },
    "valor": {
      "maximum": 100,
      "minimum": 0,
      "type": "number"
    },
    "tipoParametroId": {
      "type": "integer",
      "format": "int32"
    },
    "parcelaInicial": {
      "minimum": 1,
      "type": "integer",
      "format": "int32"
    },
    "parcelaFinal": {
      "minimum": 1,
      "type": "integer",
      "format": "int32"
    }
  }
}