  "type": "object",
  "properties": {
    "gateway_id": {
      "type": "string"
    },
    "amount": {
      "type": "integer",
      "format": "int32"
    },
    "status": {
      "type": "string"
    },
    "success": {
      "type": "boolean"
    },
    "pdf": {
      "type": "string"
    },
    "barcode": {
      "type": "string"
    },
    "line": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "attempt_count": {
      "type": "integer",
      "format": "int32"
    },
    "max_attempts": {
      "type": "integer",
