{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "FinanceiroAcordoRecordCleanForNegociacaoDTO",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int32"
    },
    "financeiro_id": {
      "type": "integer",
      "format": "int32"
    },
    "numeroParcela": {
      "type": "integer",
      "format": "int32"
    },
    "competencia": {
      "type": "object",
      "properties": {
        "year": {
          "type": "integer",
          "format": "int32"
        },
        "month": {
          "type": "string",
          "enum": [
            "JANUARY",
            "FEBRUARY",
            "MARCH",
            "APRIL",
            "MAY",
            "JUNE",
            "JULY",
            "AUGUST",
            "SEPTEMBER",
            "OCTOBER",
            "NOVEMBER",
            "DECEMBER"
          ]
        },
        "monthValue": {
          "type": "integer",
          "format": "int32"
        },
        "leapYear": {
          "type": "boolean"
        }
      }
    },
    "dataVencimento": {
      "type": "string",
      "format": "date"
    },
    "valorOriginal": {
      "type": "number"
    },
    "valorAteVencimento": {
      "type": "number"
    },
    "status": {
      "type": "string"
    },
    "tipoNegociacao": {
      "type": "string"
    }
  }
}