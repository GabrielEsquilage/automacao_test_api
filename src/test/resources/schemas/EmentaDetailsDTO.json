{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "EmentaDetailsDTO",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int32"
    },
    "nome": {
      "type": "string"
    },
    "codigo": {
      "type": "string"
    },
    "objetivos": {
      "type": "string"
    },
    "textoEmenta": {
      "type": "string"
    },
    "conteudoProgramatico": {
      "type": "string"
    },
    "metodologiaEnsino": {
      "type": "string"
    },
    "criteriosAvaliacao": {
      "type": "string"
    },
    "referenciaBasica": {
      "type": "string"
    },
    "referenciaComplementar": {
      "type": "string"
    },
    "ativo": {
      "type": "boolean"
    },
    "criacao": {
      "type": "string",
      "format": "date-time"
    },
    "disciplinas": {
      "type": "array",
      "items": {
        "$ref": "DisciplinaEmentaProjection.json"
      }
    }
  }
}