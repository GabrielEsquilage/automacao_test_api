{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "PessoaRecordResponseDTO",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int32"
    },
    "criacao": {
      "type": "string",
      "format": "date-time"
    },
    "alteracao": {
      "type": "string",
      "format": "date-time"
    },
    "ativo": {
      "type": "boolean"
    },
    "nome": {
      "type": "string"
    },
    "nomeSocial": {
      "type": "string"
    },
    "nascimento": {
      "type": ["string", "null"]
    },
    "participanteId": {
      "type": ["integer", "null"],
      "format": "int32"
    },
    "genero": {
      "$ref": "GeneroRecordCleanDTO.json"
    },
    "raca": {
      "$ref": "RacaRecordCleanDTO.json"
    },
    "orgaoExpedidorRg": {
      "anyOf": [
        { "$ref": "OrgaoExpedidorResponseDTO.json" },
        { "type": "null" }
      ]
    },
    "enderecos": {
      "type": "array",
      "items": {
        "$ref": "EnderecoRecordResponseDTO.json"
      }
    },
    "documentos": {
      "type": "array",
      "items": {
        "$ref": "DocumentoRecordResponseDTO.json"
      }
    },
    "contatos": {
      "type": "array",
      "items": {
        "$ref": "ContatoRecordResponseDTO.json"
      }
    },
    "nacionalidade": {
      "anyOf": [
        { "$ref": "NacionalidadeRecordCleanDTO.json" },
        { "type": "null" }
      ]
    },
    "usuario": {
      "anyOf": [
        { "$ref": "UsuarioRecordCleanWithoutPessoaDTO.json" },
        { "type": "null" }
      ]
    }
  }
}