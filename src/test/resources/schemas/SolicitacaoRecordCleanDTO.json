{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "SolicitacaoRecordCleanDTO",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int32"
    },
    "matricula": {
      "$ref": "MatriculaMensageriaRecordCleanDTO.json"
    },
    "waeMatricula": {
      "anyOf": [
        { "$ref": "WaeMatriculaRecordCleanDTO.json" },
        { "type": "null" }
      ]
    },
    "requerimento": {
      "$ref": "RequerimentoRecordCleanForSolicitacaoDTO.json"
    },
    "setor": {
      "$ref": "SetorRecordCleanDTO.json"
    },
    "status": {
      "$ref": "StatusCleanDTO.json"
    },
    "protocolo": {
      "type": "string"
    },
    "dataAbertura": {
      "type": "string",
      "format": "date-time"
    },
    "etapaAtual": {
      "type": "integer",
      "format": "int32"
    },
    "etapaTotal": {
      "type": "integer",
      "format": "int64"
    },
    "resposta": {
      "type": ["string", "null"]
    },
    "dataFinalizacao": {
      "type": ["string", "null"]
    },
    "responsavel": {
      "anyOf": [
        { "$ref": "UsuarioRecordCleanForMensageriaDTO.json" },
        { "type": "null" }
      ]
    },
    "slaSolicitacao": {
      "type": "number"
    }
  }
}