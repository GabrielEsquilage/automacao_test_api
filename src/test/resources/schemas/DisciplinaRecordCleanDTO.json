{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "DisciplinaRecordCleanDTO",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int32"
    },
    "nome": {
      "type": "string"
    },
    "codigo": {
      "type": "string"
    },
    "ativo": {
      "type": "boolean"
    },
    "codigoMoodle": {
      "type": "string"
    },
    "cargaHoraria": {
      "type": "integer",
      "format": "int32"
    },
    "turma": {
      "anyOf": [
        { "$ref": "TurmaRecordCleanDTO.json" },
        { "type": "null" }
      ]
    },
    "colaborador": {
      "$ref": "ColaboradorRecordCleanDTO.json"
    }
  }
}