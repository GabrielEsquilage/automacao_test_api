{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "GrupoCursoCreateRequestDTO",
  "required": [
    "nome"
  ],
  "type": "object",
  "properties": {
    "nome": {
      "maxLength": 100,
      "minLength": 0,
      "type": "string"
    },
    "cursoIds": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "int32"
      }
    },
    "cursoSelectionType": {
      "type": "string",
      "enum": [
        "IN",
        "ALL",
        "NOT_IN"
      ]
    },
    "planosPagamentoIds": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "int32"
      }
    },
    "planoSelectionType": {
      "type": "string",
      "enum": [
        "IN",
        "ALL",
        "NOT_IN"
      ]
    }
  }
}