{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "FinanceiroRecordResponseDTO",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int32"
    },
    "matricula": {
      "$ref": "MatriculaRecordCleanDTO.json"
    },
    "candidato": {
      "$ref": "CandidatoRecordCleanDTO.json"
    },
    "formaPagamento": {
      "$ref": "FormaPagamentoRecordCleanDTO.json"
    },
    "numeroParcela": {
      "type": "integer",
      "format": "int32"
    },
    "competencia": {
      "type": "object",
      "properties": {
        "year": {
          "type": "integer",
          "format": "int32"
        },
        "month": {
          "type": "string",
          "enum": [
            "JANUARY",
            "FEBRUARY",
            "MARCH",
            "APRIL",
            "MAY",
            "JUNE",
            "JULY",
            "AUGUST",
            "SEPTEMBER",
            "OCTOBER",
            "NOVEMBER",
            "DECEMBER"
          ]
        },
        "monthValue": {
          "type": "integer",
          "format": "int32"
        },
        "leapYear": {
          "type": "boolean"
        }
      }
    },
    "dataVencimento": {
      "type": "string",
      "format": "date"
    },
    "dataPagamento": {
      "type": "string",
      "format": "date-time"
    },
    "valorOriginal": {
      "type": "number"
    },
    "valorPago": {
      "type": "number"
    },
    "valorAteVencimento": {
      "type": "number"
    },
    "regimeCaixa": {
      "type": "string",
      "format": "date"
    },
    "cobrancaUnica": {
      "type": "boolean"
    },
    "tipoCobranca": {
      "$ref": "TipoCobrancaRecordCleanDTO.json"
    },
    "status": {
      "$ref": "StatusCleanDTO.json"
    },
    "erroCartaoRecorrente": {
      "type": "string"
    }
  }
}