        "ALL",
        "NOT_IN"
      ]
    },
    "filialIds": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "int32"
      }
    },
    "tipoSelecaoFilial": {
      "type": "string",
      "enum": [
        "IN",
        "ALL",
        "NOT_IN"
      ]
    }
  }
}