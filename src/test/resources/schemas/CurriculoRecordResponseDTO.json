{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "CurriculoRecordResponseDTO",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int32"
    },
    "criacao": {
      "type": "string",
      "format": "date-time"
    },
    "alteracao": {
      "type": "string",
      "format": "date-time"
    },
    "ativo": {
      "type": "boolean"
    },
    "nome": {
      "type": "string"
    },
    "nrMatriculas": {
      "type": "integer",
      "format": "int64"
    },
    "codigo": {
      "type": "string"
    },
    "horaAtividadeComplementar": {
      "type": ["number", "null"]
    },
    "horaAtividadeExtensao": {
      "type": ["number", "null"]
    },
    "curso": {
      "$ref": "CursoRecordCleanDTO.json"
    },
    "valorCurso": {
      "type": ["number", "null"]
    },
    "observacao": {
      "type": ["string", "null"]
    },
    "modulo": {
      "anyOf": [
        { "$ref": "Modulo.json" },
        { "type": "null" }
      ]
    },
    "moduloId": {
      "type": ["integer", "null"],
      "format": "int32"
    },
    "serieIngresso": {
      "$ref": "SerieRecordCleanDTO.json"
    },
    "disciplinas": {
      "type": "array",
      "items": {
        "$ref": "CurriculoDisciplinaRecordCleanForCurriculoDTO.json"
      }
    },
    "series": {
      "type": "array",
      "items": {
        "$ref": "CurriculoSerieRecordCleanForCurriculoDTO.json"
      }
    },
    "planosPagamento": {
      "type": "array",
      "items": {
        "$ref": "CurriculoPlanoPagamentoRecordCleanForCurriculoDTO.json"
      }
    }
  }
}