    },
    "formaPagamentoId": {
      "type": "integer",
      "format": "int32"
    },
    "dataPagamento": {
      "type": "string",
      "format": "date"
    },
    "justificativa": {
      "maxLength": 1000,
      "minLength": 0,
      "type": "string"
    }
  }
}